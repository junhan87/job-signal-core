# Force LF for all shell scripts — required for Linux containers (Codespaces, Lambda)
*.sh        text eol=lf

# Python and config files: normalise to LF
*.py        text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf

# Binary files: no line-ending conversion
*.png       binary
*.jpg       binary
*.zip       binary
